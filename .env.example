# Google Sheets Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# Google Sheet Tab Names
GOOGLE_SHEET_NAME_PAYMENT=Payment Form
GOOGLE_SHEET_NAME_FREETRIAL=FreeTrialMembers
GOOGLE_SHEET_NAME_PAID=PaidMembers
GOOGLE_SHEET_NAME_CONVERTED=ConvertedFromTrial

# Paytm Payment Gateway
PAYTM_MID=your_merchant_id
PAYTM_MERCHANT_KEY=your_merchant_key
PAYTM_WEBSITE=DEFAULT
PAYTM_ENVIRONMENT=production

# AiSensy WhatsApp API
AISENSY_API_KEY=your_aisensy_api_campaign_key

# AiSensy Campaign Names (must match campaigns on AiSensy dashboard)
AISENSY_CAMPAIGN_PAYMENT_SUCCESS=welcome_paid
AISENSY_CAMPAIGN_FREETRIAL_WELCOME=welcome_freetrial
AISENSY_CAMPAIGN_DAILY_SESSION=daily_session_link
AISENSY_CAMPAIGN_MID_TRIAL_NUDGE=mid_trial_nudge
AISENSY_CAMPAIGN_TRIAL_EXPIRY=trial_expiry_warning
AISENSY_CAMPAIGN_TRIAL_EXPIRED=trial_expired
AISENSY_CAMPAIGN_PAID_DAILY=paid_daily_session
AISENSY_CAMPAIGN_RENEWAL_REMINDER=renewal_reminder

# Zoom Meeting Link (personal join links redirect here)
ZOOM_MEETING_LINK=https://zoom.us/j/your-meeting-id?pwd=your-password

# CRON Job Security
CRON_SECRET=generate-a-random-32-char-secret-here
