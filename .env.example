# Environment Variables — Tayal Yoga Class
# Copy this file to .env.local and fill in the values

# ============================================
# GOOGLE SHEETS CONFIGURATION
# See guides/GOOGLE_SHEETS_SETUP.md for details
# ============================================

# Service account email from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key from the service account JSON key file
# Keep the \n characters and wrap in double quotes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Spreadsheet ID from the Google Sheet URL
# URL format: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet tab name (default: Sheet1)
GOOGLE_SHEET_NAME=Sheet1

# ============================================
# PAYTM PAYMENT GATEWAY CONFIGURATION
# See guides/PAYTM_SETUP.md for details
# ============================================

# Merchant ID from Paytm Business Dashboard
PAYTM_MID=your_merchant_id_here

# Merchant Key (SECRET — never commit this!)
PAYTM_MERCHANT_KEY=your_merchant_key_here

# Website name from Paytm Dashboard (usually "DEFAULT")
PAYTM_WEBSITE=DEFAULT

# Environment: "production" for live payments, "staging" for testing
PAYTM_ENVIRONMENT=production
